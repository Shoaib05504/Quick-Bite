# ==============================================================================
# Quick-Bite Environment Variables Configuration Templates
# ==============================================================================
# This workspace contains three separate applications: backend, frontend, and admin.
# Do NOT fill in secrets here. Instead, copy this template to the respective subfolders.
#
# E.g.,
# Copy backend/.env.example -> backend/.env
# Copy frontend/.env.example -> frontend/.env
# Copy admin/.env.example -> admin/.env
#
# ==============================================================================
# 1. Backend Environment Setup (mern-food-delivery-app-main/backend/.env)
# ==============================================================================
# PORT=8000
# MONGO_URI="mongodb+srv://<username>:<password>@cluster.mongodb.net/quickbite"
# JWT_SECRET="your_jwt_secret_key"
# STRIPE_SECRET_KEY="sk_test_..."
# RAZORPAY_KEY_ID="rzp_test_..."
# RAZORPAY_KEY_SECRET="your_razorpay_secret"
# CLOUDINARY_CLOUD_NAME="your_cloudinary_name"
# CLOUDINARY_API_KEY="your_cloudinary_api_key"
# CLOUDINARY_API_SECRET="your_cloudinary_api_secret"
# EMAIL="your_email@gmail.com"
# EMAIL_PASSWORD="your_email_app_password"
# GEMINI_API_KEY="your_gemini_api_key_for_chatbot"
# FRONTEND_URL="http://localhost:5173"
# ADMIN_URL="http://localhost:5174"

# ==============================================================================
# 2. Frontend Environment Setup (mern-food-delivery-app-main/frontend/.env)
# ==============================================================================
# VITE_API_URL="http://localhost:8000"
# VITE_SOCKET_URL="http://localhost:8000"
# VITE_APP_NAME="QuickBite"

# ==============================================================================
# 3. Admin Environment Setup (mern-food-delivery-app-main/admin/.env)
# ==============================================================================
# VITE_API_URL="http://localhost:8000"
